	local RS = game:GetService("ReplicatedStorage")
	local GameService = RS:WaitForChild("Aero"):WaitForChild("AeroRemoteServices"):WaitForChild("GameService")
	
	local RequestMaxUpgradeItem = GameService:WaitForChild("RequestMaxUpgradeItem")
	
	local button = script.Parent
	local player = game.Players.LocalPlayer
	
	local inventoryUI = player.PlayerGui:WaitForChild("Inventory")
	local wpnSelectionFrame = inventoryUI:WaitForChild("Main")
		:WaitForChild("InventoryBG")
		:WaitForChild("InventoryClipFrame")
		:WaitForChild("InventoryMainFrame")
		:WaitForChild("WpnInventoryFrame")
		:WaitForChild("WpnInvDataFrame")
		:WaitForChild("WpnSelectionPanel")
		:WaitForChild("WpnSelectionFrame")
	
	local isAutoUpgrading = false
	
	local function ParseLevel(levelText)
		if not levelText then return 0 end
		levelText = string.lower(levelText)
		local numberPart, suffix = string.match(levelText, "(%d+%.?%d*)%s*([km]?)")
		if numberPart then
			local num = tonumber(numberPart)
			if suffix == "k" then num = num * 1000
			elseif suffix == "m" then num = num * 1000000 end
			return num
		end
		return 0
	end
	
	local function GetSortedWeaponData()
		local allSlots = {}
	
		for _, v in ipairs(wpnSelectionFrame:GetChildren()) do
			if v:IsA("ImageLabel") then
				table.insert(allSlots, v)
			end
		end
	
		table.sort(allSlots, function(a, b)
			return a.LayoutOrder > b.LayoutOrder
		end)
	
		local weaponData = {}
		for index, item in ipairs(allSlots) do
			if item:FindFirstChild("Level") then
				table.insert(weaponData, {
					Index = tostring(index),
					Level = ParseLevel(item.Level.Text),
					LayoutOrder = item.LayoutOrder
				})
			end
		end
	
		table.sort(weaponData, function(a, b)
			if a.Level == b.Level then
				return a.LayoutOrder > b.LayoutOrder 
			end
			return a.Level > b.Level
		end)
	
		return weaponData
	end
	
	button.MouseButton1Click:Connect(function()
		isAutoUpgrading = not isAutoUpgrading
	
		if isAutoUpgrading then
			button.Text = "Open"
			button.BackgroundColor3 = Color3.fromRGB(95, 95, 95)
	
			task.spawn(function()
				while isAutoUpgrading do
					task.wait(2)
					if not isAutoUpgrading then break end
	
					local currentData = GetSortedWeaponData()
	
					if currentData[1] then
						local args1 = {
							[1] = "weapon",
							[2] = currentData[1].Index
						}
						RequestMaxUpgradeItem:InvokeServer(table.unpack(args1))
					end
	
					task.wait(2)
					if not isAutoUpgrading then break end
	
					local updatedData = GetSortedWeaponData()
	
					if updatedData[2] then
						local args2 = {
							[1] = "weapon",
							[2] = updatedData[2].Index
						}
						RequestMaxUpgradeItem:InvokeServer(table.unpack(args2))
					end
	
					task.wait(5)
				end
			end)
		else
			button.Text = "Closed"
			button.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
		end
	end)
end;
