	local Players = game:GetService("Players")
	local TweenService = game:GetService("TweenService")
	local LocalPlayer = Players.LocalPlayer
	
	local isEnabled = false
	local targetMeshId = "7036884767"
	local travelSpeed = 325
	
	local button = script.Parent
	
	button.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
	button.Text = "Closed"
	
	local function checkMeshId(prefab)
		if not prefab then return false end
		if prefab:IsA("MeshPart") and string.find(prefab.MeshId, targetMeshId) then
			return true
		elseif prefab:FindFirstChildOfClass("SpecialMesh") and string.find(prefab:FindFirstChildOfClass("SpecialMesh").MeshId, targetMeshId) then
			return true
		end
		return false
	end
	
	local function getClosestNode()
		local character = LocalPlayer.Character
		local rootPart = character and character:FindFirstChild("HumanoidRootPart")
		if not rootPart then return nil end
	
		local scene = workspace:FindFirstChild("Scene")
		if not scene then return nil end
	
		local resourceNodes = scene:FindFirstChild("ResourceNodes1")
		if not resourceNodes then return nil end
	
		local closestNode = nil
		local shortestDistance = math.huge
	
		for _, node in ipairs(resourceNodes:GetChildren()) do
			if node.Name == "ResourceNode" and node:IsA("BasePart") then
				local prefab = node:FindFirstChild("Prefab")
				if prefab and checkMeshId(prefab) then
					local distance = (rootPart.Position - node.Position).Magnitude
					if distance < shortestDistance then
						shortestDistance = distance
						closestNode = node
					end
				end
			end
		end
	
		return closestNode
	end
	
	local function setCharacterCollision(state)
		local character = LocalPlayer.Character
		if not character then return end
		for _, part in ipairs(character:GetDescendants()) do
			if part:IsA("BasePart") then
				part.CanCollide = state
			end
		end
	end
	
	local function moveToTarget(targetPart)
		local character = LocalPlayer.Character
		local rootPart = character and character:FindFirstChild("HumanoidRootPart")
		if not rootPart then return end
	
		local currentPos = rootPart.Position
		local targetPos = targetPart.Position
	
		if math.abs(currentPos.Y - targetPos.Y) > 2 then
			local verticalPos = Vector3.new(currentPos.X, targetPos.Y, currentPos.Z)
			local verticalDistance = math.abs(currentPos.Y - targetPos.Y)
			local verticalDuration = verticalDistance / travelSpeed
	
			local verticalCFrame = CFrame.new(verticalPos) * (rootPart.CFrame - rootPart.Position)
			local tweenInfoY = TweenInfo.new(verticalDuration, Enum.EasingStyle.Linear)
			local tweenY = TweenService:Create(rootPart, tweenInfoY, {CFrame = verticalCFrame})
	
			tweenY:Play()
	
			while tweenY.PlaybackState == Enum.PlaybackState.Playing and isEnabled do
				task.wait()
			end
	
			if not isEnabled then 
				tweenY:Cancel() 
				return 
			end
	
			currentPos = rootPart.Position
		end
	
		local horizontalPos = Vector3.new(targetPos.X, currentPos.Y, targetPos.Z)
		local horizontalDistance = (currentPos - horizontalPos).Magnitude
		local horizontalDuration = horizontalDistance / travelSpeed
	
		local horizontalCFrame = CFrame.new(horizontalPos) * (rootPart.CFrame - rootPart.Position)
		local tweenInfoXZ = TweenInfo.new(horizontalDuration, Enum.EasingStyle.Linear)
		local tweenXZ = TweenService:Create(rootPart, tweenInfoXZ, {CFrame = horizontalCFrame})
	
		tweenXZ:Play()
	
		while tweenXZ.PlaybackState == Enum.PlaybackState.Playing and isEnabled do
			task.wait()
		end
	
		if not isEnabled then
			tweenXZ:Cancel()
		end
	end
	
	local function startLoop()
		task.spawn(function()
			while isEnabled do
				setCharacterCollision(false)
	
				local targetNode = getClosestNode()
				if targetNode then
					moveToTarget(targetNode)
					if isEnabled then
						task.wait(0.5)
					end
				else
					task.wait(0.5)
				end
				task.wait(0.1)
			end
		end)
