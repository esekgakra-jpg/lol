local function C_30()
local script = G2L["30"];
	if not game:IsLoaded() then
		game.Loaded:Wait()
	end
	
	local Players = game:GetService("Players")
	local Workspace = game:GetService("Workspace")
	local ReplicatedStorage = game:GetService("ReplicatedStorage")
	local VirtualInputManager = game:GetService("VirtualInputManager")
	local TweenService = game:GetService("TweenService")
	
	local LocalPlayer = Players.LocalPlayer
	local EndQuestRequest = ReplicatedStorage:WaitForChild("Aero"):WaitForChild("AeroRemoteServices"):WaitForChild("GameService"):WaitForChild("EndQuestRequest")
	local StartQuestRequest = ReplicatedStorage:WaitForChild("Aero"):WaitForChild("AeroRemoteServices"):WaitForChild("GameService"):WaitForChild("StartQuestRequest")
	
	local HUD = LocalPlayer:WaitForChild("PlayerGui"):WaitForChild("HUD")
	local ScrollingFrame = HUD:WaitForChild("Screen"):WaitForChild("QuestTracker"):WaitForChild("questBG"):WaitForChild("ScrollingFrame")
	
	local button = script.Parent
	local isEnabled = false
	
	local targetMeshId = "7036884767"
	local travelSpeed = 250
	local visitedObjects = {}
	local farmStartLocation = CFrame.new(1910.08, 204.22, -976.70)
	
	button.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
	button.Text = "Closed"
	
	local function setCharacterCollision(state)
		local character = LocalPlayer.Character
		if not character then return end
		for _, part in ipairs(character:GetDescendants()) do
			if part:IsA("BasePart") then
				part.CanCollide = state
			end
		end
	end
	
	local function checkActiveQuest()
		for _, wgt in ipairs(ScrollingFrame:GetChildren()) do
			if wgt.Name == "questWgt" then
				local desc = wgt:FindFirstChild("desc")
				local progBG = wgt:FindFirstChild("progBG")
				local prog = progBG and progBG:FindFirstChild("prog")
	
				if desc and prog then
					local descText = string.lower(desc.Text)
					local progText = prog.Text
	
					local currentAmt, maxAmt = string.match(progText, "(%d+)%s*/%s*(%d+)")
					local targetAmount = 0
					local currentProgress = 0
					local useUIProgress = false
	
					if currentAmt and maxAmt then
						currentProgress = tonumber(currentAmt)
						targetAmount = tonumber(maxAmt)
						useUIProgress = true
					else
						local count = string.match(progText, "%d+")
						if count then
							targetAmount = tonumber(count)
						end
					end
	
					if targetAmount and targetAmount > 0 then
						if string.find(descText, "borock") then
							return "Boss", "Borock", targetAmount, currentProgress, useUIProgress, desc
						elseif string.find(descText, "demonking") or string.find(descText, "demon king") then
							return "Boss", "DemonKing", targetAmount, currentProgress, useUIProgress, desc
						elseif string.find(descText, "golden") then
							return "Egg", "Golden", targetAmount, currentProgress, useUIProgress, desc
						elseif string.find(descText, "orbs") or string.find(descText, "orb") then
							return "Orb", "Orb", targetAmount, currentProgress, useUIProgress, desc
						end
					end
				end
			end
		end
	
		return nil, nil, nil, nil, false, nil
	end
	
	local function getBossModel(bossName)
		local npcFolder = Workspace:FindFirstChild("NPC")
		if not npcFolder then return nil end
	
		if bossName == "Borock" then
			local bossFolder = npcFolder:FindFirstChild("Boss")
			return bossFolder and bossFolder:FindFirstChild("Borock")
		elseif bossName == "DemonKing" then
			local demonFolder = npcFolder:FindFirstChild("DemonKing")
			return demonFolder and demonFolder:FindFirstChild("DemonKing")
		end
		return nil
	end
	
	local function checkMeshId(prefab)
		if not prefab then return false end
		if prefab:IsA("MeshPart") and string.find(prefab.MeshId, targetMeshId) then
			return true
		elseif prefab:FindFirstChildOfClass("SpecialMesh") and string.find(prefab:FindFirstChildOfClass("SpecialMesh").MeshId, targetMeshId) then
			return true
		end
		return false
	end
	
	local function getClosestNode()
		local character = LocalPlayer.Character
		local rootPart = character and character:FindFirstChild("HumanoidRootPart")
		if not rootPart then return nil end
	
		local scene = workspace:FindFirstChild("Scene")
		if not scene then return nil end
		local resourceNodes = scene:FindFirstChild("ResourceNodes1")
		if not resourceNodes then return nil end
	
		local closestNode = nil
		local shortestDistance = math.huge
	
		for _, node in ipairs(resourceNodes:GetChildren()) do
			if node.Name == "ResourceNode" and node:IsA("BasePart") then
				local prefab = node:FindFirstChild("Prefab")
				if prefab and checkMeshId(prefab) then
					local distance = (rootPart.Position - node.Position).Magnitude
					if distance < shortestDistance then
						shortestDistance = distance
						closestNode = node
					end
				end
			end
		end
		return closestNode
	end
	
	local function getClosestEgg()
		local character = LocalPlayer.Character
		local rootPart = character and character:FindFirstChild("HumanoidRootPart")
		if not rootPart then return nil end
	
		local closestEgg = nil
		local shortestDistance = math.huge
	
		for _, obj in ipairs(Workspace:GetDescendants()) do
			if obj.Name == "Egg" and obj:IsA("BasePart") and not visitedObjects[obj] then
				local distance = (rootPart.Position - obj.Position).Magnitude
				if distance < shortestDistance then
					shortestDistance = distance
					closestEgg = obj
				end
			end
		end
		return closestEgg
	end
	
	local function moveToTarget(targetPart)
		local character = LocalPlayer.Character
		local rootPart = character and character:FindFirstChild("HumanoidRootPart")
		if not rootPart then return end
	
		local currentPos = rootPart.Position
		local targetPos = targetPart.Position
	
		if math.abs(currentPos.Y - targetPos.Y) > 2 then
			local verticalPos = Vector3.new(currentPos.X, targetPos.Y, currentPos.Z)
			local verticalDistance = math.abs(currentPos.Y - targetPos.Y)
			local verticalDuration = verticalDistance / travelSpeed
	
			local verticalCFrame = CFrame.new(verticalPos) * (rootPart.CFrame - rootPart.Position)
			local tweenInfoY = TweenInfo.new(verticalDuration, Enum.EasingStyle.Linear)
			local tweenY = TweenService:Create(rootPart, tweenInfoY, {CFrame = verticalCFrame})
	
			tweenY:Play()
	
			while tweenY.PlaybackState == Enum.PlaybackState.Playing and isEnabled do
				task.wait()
			end
	
			if not isEnabled then 
				tweenY:Cancel() 
				return 
			end
	
			currentPos = rootPart.Position
		end
	
		local horizontalPos = Vector3.new(targetPos.X, currentPos.Y, targetPos.Z)
		local horizontalDistance = (currentPos - horizontalPos).Magnitude
		local horizontalDuration = horizontalDistance / travelSpeed
	
		local horizontalCFrame = CFrame.new(horizontalPos) * (rootPart.CFrame - rootPart.Position)
		local tweenInfoXZ = TweenInfo.new(horizontalDuration, Enum.EasingStyle.Linear)
		local tweenXZ = TweenService:Create(rootPart, tweenInfoXZ, {CFrame = horizontalCFrame})
	
		tweenXZ:Play()
	
		while tweenXZ.PlaybackState == Enum.PlaybackState.Playing and isEnabled do
			task.wait()
		end
	
		if not isEnabled then
			tweenXZ:Cancel()
		end
	end
	
	local function startLoop()
		task.spawn(function()
			local killCount = 0
			local orbCount = 0
			local eggCount = 0
			local wasAlive = false
			local currentTarget = nil
			local lastQuestType = nil
			local hasTeleported = false
	
			while isEnabled do
				setCharacterCollision(false)
	
				local questType, activeTarget, targetAmount, currentProgress, useUIProgress, descLabel = checkActiveQuest()
	
				if not questType then
					StartQuestRequest:InvokeServer(table.unpack({}))
					task.wait(1)
					continue
				end
	
				if currentTarget ~= activeTarget then
					if lastQuestType == "Boss" and (questType == "Orb" or questType == "Egg") then
						local character = LocalPlayer.Character
						local myTorso = character and (character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso"))
						if myTorso then
							myTorso.CFrame = farmStartLocation
							task.wait(1)
						end
	
						if questType == "Egg" then
							hasTeleported = true
						end
					end
	
					lastQuestType = questType
					currentTarget = activeTarget
					killCount = 0
					orbCount = 0
					eggCount = 0
					wasAlive = false
					visitedObjects = {}
	
					if questType ~= "Egg" or lastQuestType ~= "Boss" then
						hasTeleported = false
					end
				end
	
				local isQuestComplete = false
				if useUIProgress then
					isQuestComplete = (currentProgress >= targetAmount)
				else
					isQuestComplete = (questType == "Boss" and killCount >= targetAmount) or 
						(questType == "Orb" and orbCount >= targetAmount) or
						(questType == "Egg" and eggCount >= targetAmount)
				end
	
				if isQuestComplete then
					EndQuestRequest:InvokeServer(table.unpack({}))
					task.wait(1)
	
					if descLabel then
						descLabel.Text = "a"
					end
	
					StartQuestRequest:InvokeServer(table.unpack({}))
	
					killCount = 0
					orbCount = 0
					eggCount = 0
					wasAlive = false
					visitedObjects = {}
					hasTeleported = false
					task.wait(0.5)
					continue
				end
	
				if questType == "Boss" then
					local bossModel = getBossModel(activeTarget)
					if bossModel then
						local torso = bossModel:FindFirstChild("Torso") or bossModel:FindFirstChild("HumanoidRootPart")
						local humanoid = bossModel:FindFirstChildOfClass("Humanoid")
	
						if torso and humanoid and humanoid.Health > 0 then
							wasAlive = true
							local character = LocalPlayer.Character
							local myTorso = character and (character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso"))
	
							if myTorso then
								myTorso.CFrame = torso.CFrame * CFrame.new(0, 0, 2)
