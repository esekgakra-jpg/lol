local function C_53()
local script = G2L["53"];
	local TweenService = game:GetService("TweenService")
	local Players = game:GetService("Players")
	local LocalPlayer = Players.LocalPlayer
	
	local button = script.Parent 
	
	local HAREKET_HIZI = 100
	local ISINLANMA_KOORDINATI = Vector3.new(20433.5, 702.222, -1688.27)
	
	local isRunning = false
	local currentSessionID = 0
	local knownMines = {}  
	local safePath = {}    
	
	local function isColor(color, r, g, b)
		local cr = math.round(color.R * 255)
		local cg = math.round(color.G * 255)
		local cb = math.round(color.B * 255)
		return math.abs(cr - r) <= 20 and math.abs(cg - g) <= 20 and math.abs(cb - b) <= 20
	end
	
	local activeTween = nil
	
	local function puruzsuzGit(hedefCFrame, targetCell, cellsFolder, currentRowIndex)
		local character = LocalPlayer.Character
		local hrp = character and character:FindFirstChild("HumanoidRootPart")
		if not hrp then return false end
	
		local netHedef = typeof(hedefCFrame) == "CFrame" and hedefCFrame or hedefCFrame.CFrame
		netHedef = netHedef * CFrame.new(0, 2.5, 0)
	
		local mesafe = (netHedef.Position - hrp.Position).Magnitude
		local sure = mesafe / HAREKET_HIZI
	
		if sure > 0 then
			local tweenInfo = TweenInfo.new(sure, Enum.EasingStyle.Linear)
			if activeTween then activeTween:Cancel() end
	
			activeTween = TweenService:Create(hrp, tweenInfo, {CFrame = netHedef})
			activeTween:Play()
	
			local completed = false
			local connection
			connection = activeTween.Completed:Connect(function()
				completed = true
			end)
	
			local startWait = os.clock()
			while not completed and (os.clock() - startWait < sure + 0.2) do
				local tehlikeVar = false
	
				if targetCell then
					local btn = targetCell:FindFirstChild("Button")
					if btn and isColor(btn.Color, 255, 99, 99) then
						tehlikeVar = true
					end
				end
	
				if not tehlikeVar and cellsFolder and currentRowIndex then
					for r = math.max(1, currentRowIndex - 1), math.min(20, currentRowIndex + 1) do
						local rowFolder = cellsFolder:FindFirstChild("Row" .. r)
						if rowFolder then
							for _, cell in ipairs(rowFolder:GetChildren()) do
								if cell.Name == "MineCell" then
									local btn = cell:FindFirstChild("Button")
									if btn and isColor(btn.Color, 255, 99, 99) then
										local pos = cell:IsA("Model") and cell:GetPivot().Position or cell.Position
										if (pos - hrp.Position).Magnitude < 5 then
											tehlikeVar = true
											break
										end
									end
								end
							end
						end
						if tehlikeVar then break end
					end
				end
	
				if tehlikeVar then
					if activeTween then activeTween:Cancel() end
					hrp.Anchored = true 
					hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
					hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
					return false
				end
	
				task.wait(0.02)
			end
	
			if connection then connection:Disconnect() end
			activeTween = nil
		end
		return true
	end
	
	local function guvenliGeriDon(hedefCFrame)
		local character = LocalPlayer.Character
		local hrp = character and character:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
	
		local netHedef = typeof(hedefCFrame) == "CFrame" and hedefCFrame or hedefCFrame.CFrame
	
		if activeTween then activeTween:Cancel() end
	
		local t1 = TweenService:Create(hrp, TweenInfo.new(0.15, Enum.EasingStyle.Linear), {CFrame = hrp.CFrame * CFrame.new(0, 8, 0)})
		t1:Play()
		t1.Completed:Wait()
	
		local mesafe = (netHedef.Position - hrp.Position).Magnitude
		local sure = mesafe / (HAREKET_HIZI * 1.5) 
		local t2 = TweenService:Create(hrp, TweenInfo.new(sure, Enum.EasingStyle.Linear), {CFrame = netHedef * CFrame.new(0, 8, 0)})
		t2:Play()
		t2.Completed:Wait()
	
		local t3 = TweenService:Create(hrp, TweenInfo.new(0.15, Enum.EasingStyle.Linear), {CFrame = netHedef * CFrame.new(0, 2.5, 0)})
		t3:Play()
		t3.Completed:Wait()
	end
	
	local function startPathfinding(mySession)
		local minefield = workspace:FindFirstChild("Scene") 
			and workspace.Scene:FindFirstChild("Minefield")
	
		local cellsFolder = minefield and minefield:FindFirstChild("Cells")
	
		if not cellsFolder then
			isRunning = false
			button.Text = "Failed To Load"
			return
		end
	
		while isRunning and currentSessionID == mySession do
			local mapReset = false
			for _, safeCell in pairs(safePath) do
				if safeCell and safeCell:FindFirstChild("Button") then
					if isColor(safeCell.Button.Color, 60, 61, 74) then
						mapReset = true
						break
					end
				end
			end
	
			if mapReset then
				knownMines = {}
				safePath = {}
				button.Text = "Open"
				task.wait(1)
				continue
			end
	
			local hitMineThisRun = false
			local i = 1 
	
			while i <= 20 do
				if not isRunning or currentSessionID ~= mySession then break end
	
				local rowName = "Row" .. i
				local row = cellsFolder:FindFirstChild(rowName)
	
				if row and row:IsA("Folder") then
	
					for _, cell in ipairs(row:GetChildren()) do
						if cell.Name == "MineCell" and not knownMines[cell] then
							local btn = cell:FindFirstChild("Button")
							if btn and isColor(btn.Color, 255, 99, 99) then
								knownMines[cell] = true
							end
						end
					end
	
					if safePath[i] and safePath[i]:FindFirstChild("Button") then
						local safeCell = safePath[i]
						local safeBtn = safeCell.Button
	
						if isColor(safeBtn.Color, 255, 99, 99) then
							knownMines[safeCell] = true
							hitMineThisRun = true
							break
						end
	
						if not puruzsuzGit(safeBtn.CFrame, safeCell, cellsFolder, i) then
							hitMineThisRun = true
							break
						end
	
						task.wait(0.1) 
	
						if isColor(safeBtn.Color, 255, 99, 99) then
							knownMines[safeCell] = true
							hitMineThisRun = true
							break
						end
	
						i = i + 1 
					else
						local candidates = {}
						local character = LocalPlayer.Character
						local hrp = character and character:FindFirstChild("HumanoidRootPart")
	
						if not hrp then 
							hitMineThisRun = true
							break 
						end
	
						local minMesafe = math.huge
						for _, cell in ipairs(row:GetChildren()) do
							if cell.Name == "MineCell" then
								local pos = cell:IsA("Model") and cell:GetPivot().Position or cell.Position
								local dist = (pos - hrp.Position).Magnitude
								if dist < minMesafe then
									minMesafe = dist
								end
							end
						end
	
						local maxMesafe = minMesafe * 1.8 + 2 
	
						for _, cell in ipairs(row:GetChildren()) do
							if cell.Name == "MineCell" and not knownMines[cell] then
								local btn = cell:FindFirstChild("Button")
								if btn then
									if isColor(btn.Color, 60, 61, 74) or isColor(btn.Color, 109, 193, 0) then
										local pos = cell:IsA("Model") and cell:GetPivot().Position or cell.Position
										local dist = (pos - hrp.Position).Magnitude
	
										if dist <= maxMesafe then
											table.insert(candidates, cell)
										end
									end
								end
							end
						end
	
						table.sort(candidates, function(a, b)
							local btnA = a:FindFirstChild("Button")
							local btnB = b:FindFirstChild("Button")
	
							local isGreenA = btnA and isColor(btnA.Color, 109, 193, 0)
							local isGreenB = btnB and isColor(btnB.Color, 109, 193, 0)
	
							if isGreenA and not isGreenB then return true end
							if isGreenB and not isGreenA then return false end
	
							local aPos = a:IsA("Model") and a:GetPivot().Position or a.Position
							local bPos = b:IsA("Model") and b:GetPivot().Position or b.Position
							return (aPos - hrp.Position).Magnitude < (bPos - hrp.Position).Magnitude
						end)
	
						local candidateCell = candidates[1]
	
						if candidateCell then
							local btn = candidateCell.Button
	
							if not puruzsuzGit(btn.CFrame, candidateCell, cellsFolder, i) then
								hitMineThisRun = true
								break
							end
	
							task.wait(0.15) 
	
							local startWait = os.clock()
							while os.clock() - startWait < 3 do
								if isColor(btn.Color, 255, 99, 99) or isColor(btn.Color, 109, 193, 0) then
									break
								end
								task.wait(0.05)
							end
	
							if isColor(btn.Color, 255, 99, 99) then
								knownMines[candidateCell] = true
								hitMineThisRun = true
								safePath[i] = nil 
								break
							elseif isColor(btn.Color, 109, 193, 0) then
								safePath[i] = candidateCell
